import java.util.Scanner;

public class PascalsTriangle {

       public static void buildRow(int row, int[] arr) {
            //create the first row as just 1
        if (row == 0) {
            arr[0] = 1;
            return;
        }
 //build the previous row first
        buildRow(row - 1, arr);


        for (int i = row; i >= 1; i--) {
            //make it so that each interior value is the sum of the two above
            arr[i] = arr[i] + arr[i - 1];
        }
         //ensure that the left edge is always 1
        arr[0] = 1;
    }


    //print all values in the given row array up to the specified row number
    public static void printRow(int row, int[] arr) {
         //print each value in the row
        for (int i = 0; i <= row; i++) {
            System.out.print(arr[i] + " ");
        }
        System.out.println();
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter the row number of Pascal's Triangle to display: ");
        int n = scanner.nextInt();
 //create the array to hold values for the Nth row
        int[] row = new int[n + 1];
 //recursively compute the row
        buildRow(n, row);

        System.out.println("Row " + n + " of Pascal's Triangle:");
         //print the result
        printRow(n, row);

        scanner.close();
    
    }
    
}

