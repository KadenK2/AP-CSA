// ── NEW: sound imports ─────────────────────────────────────────────────────────
import javax.sound.sampled.AudioFormat;
import javax.sound.sampled.AudioSystem;
import javax.sound.sampled.Clip;
import javax.sound.sampled.LineUnavailableException;
import javax.sound.sampled.SourceDataLine;

/**
* SoundPlayer – generates simple sounds entirely in code (no audio files needed).
*
* Three sounds:
* playClunk() – dull low thud when nothing is found
* playShark() – rising screech + descending wail ("SHARK!")
* playWin() – cheerful ascending chime when the Golden Shell is collected
*/
class SoundPlayer
{
// ── internal helper: write a single sine-tone segment to a byte buffer ─────
private static void writeTone(byte[] buf, int offset, int samples,
double hz, double vol, int sampleRate)
{
for (int i = 0; i < samples; i++)
{
double angle = 2.0 * Math.PI * hz * i / sampleRate;
double v = Math.sin(angle) * vol * 127.0;

// simple linear fade-out over last 10% to avoid clicks
int fadeStart = (int)(samples * 0.9);
if (i > fadeStart)
{
double factor = 1.0 - ((double)(i - fadeStart) / (samples - fadeStart));
v *= factor;
}

buf[offset + i] = (byte) Math.max(-127, Math.min(127, (int) v));
}
}

// ── internal: play a raw 8-bit mono byte array ────────────────────────────
private static void playBytes(byte[] data, int sampleRate)
{
try
{
AudioFormat fmt = new AudioFormat(sampleRate, 8, 1, true, false);
SourceDataLine line = AudioSystem.getSourceDataLine(fmt);
line.open(fmt, data.length);
line.start();
line.write(data, 0, data.length);
line.drain();
line.close();
}
catch (LineUnavailableException e)
{
// If audio hardware is unavailable just skip sound silently
}
}

/**
* Dull low "clunk" – played when a zone has nothing to find.
* Two short descending tones at low frequency.
*/
public static void playClunk()
{
int rate = 22050;
int samples = rate / 4; // 0.25 s total
byte[] buf = new byte[samples];

// first thud: 120 Hz, first half
writeTone(buf, 0, samples / 2, 120.0, 0.6, rate);
// second lower thud: 80 Hz, second half
writeTone(buf, samples / 2, samples / 2, 80.0, 0.4, rate);

playBytes(buf, rate);
}

/**
* "SHARK!" alarm – rising screech followed by a sharp drop.
* Simulates a sudden danger sting.
*/
public static void playShark()
{
int rate = 22050;
int totalSamples = (int)(rate * 0.8); // 0.8 s total
byte[] buf = new byte[totalSamples];

// sweep up from 300 Hz → 900 Hz over first 0.4 s
int sweep = rate * 4 / 10;
for (int i = 0; i < sweep; i++)
{
double hz = 300.0 + (600.0 * i / sweep);
double angle = 2.0 * Math.PI * hz * i / rate;
double vol = 0.75 * (1.0 - 0.4 * ((double) i / sweep)); // slight fade
buf[i] = (byte)(Math.sin(angle) * vol * 127.0);
}

// sharp drop: two short pulses at 800 Hz and 140 Hz
int p1Start = sweep;
int p1Len = rate / 5;
writeTone(buf, p1Start, Math.min(p1Len, totalSamples - p1Start),
800.0, 0.8, rate);

int p2Start = p1Start + p1Len;
int p2Len = rate / 5;
if (p2Start < totalSamples)
{
writeTone(buf, p2Start, Math.min(p2Len, totalSamples - p2Start),
140.0, 0.6, rate);
}

playBytes(buf, rate);
}

/**
* Shell-found chime – three ascending notes (C-E-G feel).
*/
public static void playWin()
{
int rate = 22050;
int noteLen = rate / 4; // each note 0.25 s
int totalSamples = noteLen * 3;
byte[] buf = new byte[totalSamples];

writeTone(buf, 0, noteLen, 523.25, 0.7, rate); // C5
writeTone(buf, noteLen, noteLen, 659.25, 0.7, rate); // E5
writeTone(buf, noteLen * 2, noteLen, 783.99, 0.8, rate); // G5

playBytes(buf, rate);
}
}
