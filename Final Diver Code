//create ocean class. extension of location class
class Ocean extends Location
{
private int currentDepth;
private final ArrayList<Zone> zones;

// ── NEW: index of the zone that holds the Golden Shell (for proximity clue)
private int shellZoneIndex = -1;

public Ocean()
{
super("The Deep Ocean");
currentDepth = 0;
zones = new ArrayList<>();
}

//load zones from zones.txt instead of hardcoding
public void loadZones(String filename)
{
try
{
Scanner fileScanner = new Scanner(new FileReader(filename));
while (fileScanner.hasNextLine())
{
String line = fileScanner.nextLine().trim();

//skip comment lines and blank lines
if (line.length() == 0 || line.charAt(0) == '#')
{
continue;
}

//split line by comma
String[] parts = line.split(",");
int id = Integer.parseInt(parts[0].trim());
String type = parts[1].trim();
boolean shark = parts[2].trim().equals("true");
boolean shell = parts[3].trim().equals("true");

Zone zone;
if (type.equals("CAVE"))
{
zone = new Cave(id, shark, shell);
}
else
{
zone = new Zone(id, false);
// plain ZONEs can also hold shells (add one if zones.txt says so)
if (shell) { zone.addItem(new GoldenShell()); }
}

// remember where the shell is for proximity clues
if (shell) { shellZoneIndex = zones.size(); }

zones.add(zone);
}
fileScanner.close();
}
catch (IOException e)
{
System.out.println("Error reading zones file: " + e.getMessage());
}
}

public int getCurrentDepth() { return currentDepth; }
public boolean hasMoreZones() { return currentDepth < zones.size(); }

public Zone getNextZone()
{
if (currentDepth < zones.size())
{
Zone next = zones.get(currentDepth);
currentDepth++;
return next;
}
return null;
}

// ── NEW: proximity clue ───────────────────────────────────────────────────
/**
* Returns a temperature-style clue string based on how far the diver is
* from the shell zone.
*
* distance 0 → "🔥 SCALDING HOT – the shell is right here!"
* distance 1 → "♨ Warm – the shell is very close."
* distance 2 → "🌊 Cool – the shell is nearby."
* distance ≥ 3 → "❄ Very cold – the shell is far away."
* not found → (empty – shell already collected or not in ocean)
*/
public String getProximityClue()
{
if (shellZoneIndex < 0) { return ""; }

int distance = shellZoneIndex - (currentDepth - 1); // currentDepth was already incremented
if (distance < 0) { return ""; } // already passed it

if (distance == 0) { return "*** SCALDING HOT — the Golden Shell is right here! ***"; }
if (distance == 1) { return " ~~~ Warm — the shell is very close. ~~~"; }
if (distance == 2) { return " ~ Cool — the shell is nearby."; }
return " * Very cold — the shell is far away.";
}
